#include <Arduino.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <time.h>

// --- WiFi ---
const char* ssid     = "uwu";
const char* password = "12345678";  // remove if open

// --- Google Calendar ---
const char* apiKey     = "-------";
const char* calendarId = "---------";

// --- Pins ---
int ledPin    = 5;
int buzzerPin = 18;
int potPin    = 34;
int buttonPin = 15;

// --- OLED ---
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// --- Rocky phrases ---
const char* phrases[] = {
  "Fist my bump!",
  "Eridians do not\nfear Mondays.",
  "You are not dead.\nThis is good.",
  "Problem? Solve it.\nRocky believes.",
  "Question? Science.\nAlways science.",
  "You got this,\nhuman friend!",
  "Ammonia good.\nYou also good.",
  "Do not give up.\nRocky is here.",
  "Today: survive.\nTomorrow: thrive.",
  "Astrophage cannot\nstop you either.",
  "Grace did it.\nSo can you.",
  "Many problem.\nMuch solve. Wow.",
  "You are smart.\nRocky confirm.",
  "Keep going.\nEridians never quit.",
  "Small step today.\nBig win tomorrow.",
  "Rocky proud of\nyou. Very proud.",
  "Difficult? Yes.\nImpossible? No.",
  "You figure out.\nYou always do.",
  "Fist bump for\ncourage today!",
  "Science your way\nthrough this!"
};
const int phraseCount = 20;

// --- Alarm state ---
enum AlarmState { IDLE, SETTING_HOUR, SETTING_MINUTE, ALARM_SET, ALARM_FIRING };
AlarmState alarmState = IDLE;
int alarmHour   = 0;
int alarmMinute = 0;
int pendingHour = 0;
bool alarmEnabled = false;

// --- Button ---
bool lastButtonState = HIGH;
unsigned long lastDebounce = 0;
const unsigned long debounceDelay = 50;

// --- Slide/page state ---
int currentPage = 0;                          // 0=time 1=calendar 2=phrase 3=alarm
unsigned long lastSlide   = 0;
unsigned long lastCheck   = 0;
unsigned long lastPhrase  = 0;
const unsigned long slideInterval  = 4000;
const unsigned long checkInterval  = 60000;
const unsigned long phraseInterval = 30000;
int currentPhrase = 0;
String nextReminder = "None";
String reminderTime = "";

// --- NTP ---
void syncTime() {
  configTime(-21600, 0, "pool.ntp.org", "time.nist.gov");  // CST Austin
  Serial.print("Syncing time");
  int attempts = 0;
  while (time(nullptr) < 1000000000 && attempts < 40) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  Serial.println(time(nullptr) < 1000000000 ? " FAILED" : " done");
}

// --- Buzzer alert ---
void buzzAlert(int times) {
  int potValue  = analogRead(potPin);
  int dutyCycle = map(potValue, 0, 4095, 0, 255);
  for (int i = 0; i < times; i++) {
    ledcWrite(0, dutyCycle);
    delay(400);
    ledcWrite(0, 0);
    delay(200);
  }
}

// --- Page dot indicator ---
void drawDots(int activePage) {
  for (int i = 0; i < 4; i++) {
    int x = 52 + i * 8;
    if (i == activePage) display.fillCircle(x, 62, 2, SSD1306_WHITE);
    else display.drawCircle(x, 62, 2, SSD1306_WHITE);
  }
}

// --- Page 1: Time ---
void drawTimePage() {
  time_t now = time(nullptr);
  struct tm* t = localtime(&now);
  char timeBuf[10];
  char dateBuf[20];
  strftime(timeBuf, sizeof(timeBuf), "%H:%M:%S", t);
  strftime(dateBuf, sizeof(dateBuf), "%a %d %b %Y", t);

  display.clearDisplay();
  drawDots(0);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(35, 2);
  display.println("ROCKY TIME");
  display.drawLine(0, 12, 128, 12, SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println(timeBuf);
  display.setTextSize(1);
  display.setCursor(20, 44);
  display.println(dateBuf);
  display.display();
}

// --- Page 2: Calendar ---
void drawCalendarPage() {
  display.clearDisplay();
  drawDots(1);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(28, 2);
  display.println("NEXT REMINDER");
  display.drawLine(0, 12, 128, 12, SSD1306_WHITE);

  if (nextReminder == "None") {
    display.setCursor(20, 28);
    display.println("All clear!");
    display.setCursor(15, 42);
    display.println("No reminders :)");
  } else {
    String title = nextReminder;
    if (title.length() > 16) {
      display.setCursor(0, 18);
      display.println(title.substring(0, 16));
      display.setCursor(0, 30);
      display.println(title.substring(16, 32));
    } else {
      display.setCursor(0, 24);
      display.println(title);
    }
    display.setCursor(0, 48);
    display.print("At: ");
    display.println(reminderTime);
  }
  display.display();
}

// --- Page 3: Phrase ---
void drawPhrasePage() {
  display.clearDisplay();
  drawDots(2);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(38, 2);
  display.println("ROCKY SAYS");
  display.drawLine(0, 12, 128, 12, SSD1306_WHITE);
  display.setCursor(0, 22);
  display.println(phrases[currentPhrase]);
  display.display();
}

// --- Page 4: Alarm ---
void drawAlarmPage() {
  display.clearDisplay();
  drawDots(3);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(40, 2);
  display.println("ALARM");
  display.drawLine(0, 12, 128, 12, SSD1306_WHITE);

  if (alarmState == SETTING_HOUR) {
    int potValue = analogRead(potPin);
    pendingHour  = map(potValue, 0, 4095, 1, 12);
    display.setCursor(0, 18);
    display.println("Set hour:");
    display.setTextSize(2);
    display.setCursor(45, 32);
    display.print(pendingHour);
    display.setTextSize(1);
    display.setCursor(0, 52);
    display.println("Press button to set");

  } else if (alarmState == SETTING_MINUTE) {
    int potValue  = analogRead(potPin);
    alarmMinute   = map(potValue, 0, 4095, 0, 59);
    display.setCursor(0, 18);
    display.println("Set minute:");
    display.setTextSize(2);
    display.setCursor(10, 32);
    char buf[10];
    sprintf(buf, "%02d:%02d", pendingHour, alarmMinute);
    display.print(buf);
    display.setTextSize(1);
    display.setCursor(0, 52);
    display.println("Press button to set");

  } else if (alarmState == ALARM_SET) {
    display.setCursor(20, 18);
    display.println("Alarm set for:");
    display.setTextSize(2);
    display.setCursor(20, 32);
    char buf[10];
    sprintf(buf, "%02d:%02d", alarmHour, alarmMinute);
    display.print(buf);
    display.setTextSize(1);
    display.setCursor(10, 52);
    display.println("Hold to cancel");

  } else if (alarmState == ALARM_FIRING) {
    display.setTextSize(2);
    display.setCursor(10, 20);
    display.println("WAKE UP!");
    display.setTextSize(1);
    display.setCursor(5, 45);
    display.println("Press to dismiss");

  } else {
    // IDLE — no alarm set
    display.setCursor(15, 20);
    display.println("No alarm set.");
    display.setCursor(0, 36);
    display.println("Press button to");
    display.setCursor(0, 46);
    display.println("set one!");
  }

  display.display();
}

// --- Button press handler ---
void handleButton() {
  if (alarmState == IDLE) {
    alarmState = SETTING_HOUR;
    currentPage = 3;          // jump to alarm page
    lastSlide = millis();

  } else if (alarmState == SETTING_HOUR) {
    alarmHour  = pendingHour;
    alarmState = SETTING_MINUTE;

  } else if (alarmState == SETTING_MINUTE) {
    alarmState   = ALARM_SET;
    alarmEnabled = true;
    Serial.printf("Alarm set for %02d:%02d\n", alarmHour, alarmMinute);

  } else if (alarmState == ALARM_FIRING) {
    // dismiss alarm
    alarmState   = IDLE;
    alarmEnabled = false;
    ledcWrite(0, 0);
  }
}

// --- Long press to cancel alarm ---
void handleLongPress() {
  if (alarmState == ALARM_SET) {
    alarmState   = IDLE;
    alarmEnabled = false;
    Serial.println("Alarm cancelled");
  }
}

// --- Check if alarm should fire ---
void checkAlarm() {
  if (!alarmEnabled || alarmState != ALARM_SET) return;

  time_t now = time(nullptr);
  struct tm* t = localtime(&now);

  if (t->tm_hour == alarmHour && t->tm_min == alarmMinute && t->tm_sec < 5) {
    alarmState  = ALARM_FIRING;
    currentPage = 3;
  }
}

// --- Fire alarm buzzer ---
void handleFiringAlarm() {
  if (alarmState != ALARM_FIRING) return;
  int potValue  = analogRead(potPin);
  int dutyCycle = map(potValue, 0, 4095, 0, 255);
  ledcWrite(0, dutyCycle);
  delay(500);
  ledcWrite(0, 0);
  delay(500);
}

// --- Fetch calendar ---
void checkReminders() {
  if (WiFi.status() != WL_CONNECTED) return;

  time_t now = time(nullptr);
  struct tm* t = gmtime(&now);
  char timeBuf[25];
  strftime(timeBuf, sizeof(timeBuf), "%Y-%m-%dT%H:%M:%SZ", t);

  String url = "https://www.googleapis.com/calendar/v3/calendars/";
  url += calendarId;
  url += "/events?key=";
  url += apiKey;
  url += "&timeMin=";
  url += timeBuf;
  url += "&maxResults=5&singleEvents=true&orderBy=startTime";

  HTTPClient http;
  http.begin(url);
  int code = http.GET();

  if (code == 200) {
    String payload = http.getString();
    DynamicJsonDocument doc(8192);
    deserializeJson(doc, payload);
    JsonArray items = doc["items"].as<JsonArray>();

    if (items.size() == 0) {
      nextReminder = "None";
      reminderTime = "";
    } else {
      String title = items[0]["summary"] | "No title";
      String start = items[0]["start"]["dateTime"] | items[0]["start"]["date"] | "";
      nextReminder = title;
      reminderTime = start.length() > 16 ? start.substring(11, 16) : start;

      struct tm eventTime = {};
      strptime(start.c_str(), "%Y-%m-%dT%H:%M:%S", &eventTime);
      time_t eventEpoch = mktime(&eventTime);
      long diff = eventEpoch - now;
      if (diff >= 0 && diff <= 300) {
        display.clearDisplay();
        display.setCursor(20, 0);  display.println("!! REMINDER !!");
        display.drawLine(0, 12, 128, 12, SSD1306_WHITE);
        display.setCursor(0, 20); display.println(title);
        display.display();
        buzzAlert(5);
      }
    }
  }
  http.end();
}

void setup() {
  pinMode(ledPin, OUTPUT);
  pinMode(buttonPin, INPUT_PULLUP);
  Serial.begin(115200);

  ledcSetup(0, 2000, 8);
  ledcAttachPin(buzzerPin, 0);

  Wire.begin(21, 22);
  delay(100);
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED init failed");
    while (true);
  }

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(30, 20);
  display.println("Rocky waking");
  display.setCursor(40, 35);
  display.println("up...");
  display.display();

  WiFi.mode(WIFI_STA);
  WiFi.disconnect(true);
  delay(100);
  WiFi.begin(ssid, password);
  Serial.print("Connecting");
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println(" connected!");
    delay(1000);
    syncTime();
    checkReminders();
  } else {
    Serial.println(" FAILED");
    display.clearDisplay();
    display.setCursor(0, 0);
    display.println("WiFi failed");
    display.println("Running offline");
    display.display();
    delay(2000);
  }

  randomSeed(analogRead(0));
  currentPhrase = random(phraseCount);
  drawTimePage();
}

void loop() {
  unsigned long now = millis();

  // --- Button reading with debounce ---
  bool reading = digitalRead(buttonPin);
  static unsigned long pressStart = 0;
  static bool longPressHandled = false;

  if (reading != lastButtonState) {
    lastDebounce = now;
  }

  if ((now - lastDebounce) > debounceDelay) {
    if (reading == LOW && lastButtonState == HIGH) {
      // button just pressed
      pressStart = now;
      longPressHandled = false;
    }
    if (reading == LOW && !longPressHandled && (now - pressStart > 1500)) {
      // long press (1.5s)
      handleLongPress();
      longPressHandled = true;
    }
    if (reading == HIGH && lastButtonState == LOW && !longPressHandled) {
      // short press released
      handleButton();
    }
  }
  lastButtonState = reading;

  // --- Alarm firing ---
  if (alarmState == ALARM_FIRING) {
    handleFiringAlarm();
    drawAlarmPage();
    return;   // skip sliding while alarm fires
  }

  // --- Setting alarm — stay on alarm page and update live ---
  if (alarmState == SETTING_HOUR || alarmState == SETTING_MINUTE) {
    drawAlarmPage();
    delay(50);
    return;   // skip sliding while setting
  }

  // --- Check alarm trigger ---
  checkAlarm();

  // --- Slide pages ---
  if (now - lastSlide >= slideInterval) {
    lastSlide = now;
    currentPage = (currentPage + 1) % 4;
    if (currentPage == 0)      drawTimePage();
    else if (currentPage == 1) drawCalendarPage();
    else if (currentPage == 2) drawPhrasePage();
    else if (currentPage == 3) drawAlarmPage();
  }

  // refresh time page every second
  if (currentPage == 0 && now % 1000 < 50) drawTimePage();

  // check calendar every 60s
  if (now - lastCheck >= checkInterval || lastCheck == 0) {
    lastCheck = now;
    checkReminders();
  }

  // rotate phrase every 30s
  if (now - lastPhrase >= phraseInterval) {
    lastPhrase = now;
    currentPhrase = (currentPhrase + 1) % phraseCount;
  }

  delay(50);
}
